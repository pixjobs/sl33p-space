# Required: Gemini API key for agent + music generation
GOOGLE_API_KEY=your-gemini-api-key

# Dev mode: bypasses Firebase Auth, uses a fixed dev user
DEV_MODE=true

# MongoDB (required for sleep data persistence)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DATABASE=sl33p-space

# NASA APOD (optional, for cosmos background mode)
# NASA_API_KEY=DEMO_KEY

# Firebase Auth (production — leave unset for DEV_MODE)
# FIREBASE_SERVICE_ACCOUNT=path/to/firebase-service-account.json
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_APP_ID=your-firebase-app-id
